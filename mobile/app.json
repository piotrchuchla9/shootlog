{
  "expo": {
    "name": "ShootLog",
    "slug": "shootlog",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "description": "Aplikacja dla zawodników strzelectwa sportowego — IPSC, PZSS. Przeglądaj zawody, zapisuj ulubione, śledź terminy i otrzymuj powiadomienia o nowych eventach.",
    "keywords": [
      "strzelectwo",
      "IPSC",
      "PZSS",
      "zawody",
      "shooting"
    ],
    "primaryColor": "#E87722",
    "icon": "./assets/images/icon.png",
    "scheme": "shootlog",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "pl.shootlog.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ShootLog używa lokalizacji, aby pokazać zawody strzeleckie w pobliżu.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ShootLog używa lokalizacji, aby pokazać zawody strzeleckie w pobliżu."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "package": "pl.shootlog.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D0D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 160
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ShootLog używa lokalizacji, aby pokazać zawody strzeleckie w pobliżu."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.913794272204-jq6tvjg50ma8bol4p685694ug0gppja3"
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "pl.shootlog.app.widgets",
          "groupIdentifier": "group.pl.shootlog.app",
          "widgets": [
            {
              "name": "NearestEventsWidget",
              "displayName": "Najbliższe zawody",
              "description": "Nadchodzące zawody strzeleckie",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
